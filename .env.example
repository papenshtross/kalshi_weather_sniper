# Polymarket
# Runtime wallet private keys are loaded from the encrypted SOPS registry;
# do not put POLYMARKET_PRIVATE_KEY or API tokens in env files.
POLYBOT_WALLET_ID=default
POLYMARKET_PROXY_ADDRESS=0x...                # proxy/deposit wallet address
POLYMARKET_SIGNATURE_TYPE=3                   # 1=legacy POLY_PROXY, 3=deposit wallet / POLY_1271
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Goldsky subgraph (public, no key required)
GOLDSKY_GRAPHQL_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/orders-subgraph/prod/gn

# Nautilus persistence (optional; used by live runner + Grafana)
NAUTILUS_DB_URL=postgresql://polybot:polybot@localhost:5432/polybot

LOG_LEVEL=INFO
